# Binaries
/kura

# Database
.jobs.db
.jobs.db-wal
.jobs.db-shm

# Go
vendor/
/.gocache/
/.gotmp/

# OS
.DS_Store

# local files
local/

# dev-instance state (scripts/dev-instance.sh)
/.dev-instance/

# Terraform / OpenTofu: provider binaries, local state, plan output, and
# real per-client tfvars are never committed. The .terraform.lock.hcl
# (provider checksums) and *.tfvars.example ARE committed.
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log
*.tfvars
!*.tfvars.example

