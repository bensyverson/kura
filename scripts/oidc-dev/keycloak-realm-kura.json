{
  "realm": "kura",
  "enabled": true,
  "displayName": "Kura (dev)",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": false,
  "verifyEmail": false,
  "sslRequired": "none",
  "users": [
    {
      "username": "alice",
      "email": "alice@kura.test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Alice",
      "lastName": "Example",
      "credentials": [
        {
          "type": "password",
          "value": "alice",
          "temporary": false
        }
      ],
      "realmRoles": [
        "default-roles-kura"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "kura",
      "name": "Kura",
      "description": "Kura serve — dev client. Confidential, code flow.",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
